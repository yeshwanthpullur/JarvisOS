# Byte-compiled files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment files
.env
.env.*
!.env.example

# Logs and runtime output
logs/*
!logs/.gitkeep
*.log

# Local data
data/*
!data/.gitkeep
*.db
*.sqlite
*.sqlite3

# Test and coverage artifacts
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# Type checker and linter caches
.mypy_cache/
.ruff_cache/
.pyre/

# Build artifacts
build/
dist/
*.egg-info/

# IDE and OS files
.idea/
.vscode/
.DS_Store
Thumbs.db
